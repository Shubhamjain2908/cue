# Massive.com REST API key (https://massive.com/dashboard — rebranded from Polygon.io; env name unchanged)
POLYGON_API_KEY=replace_me_massive
# Optional — unused by Phase 2 enrichment (Yahoo). Keep if you add Alpha Vantage later.
# ALPHA_VANTAGE_API_KEY=

# LLM: anthropic | openai | google
LLM_PROVIDER=anthropic
LLM_MAX_TOKENS=600
ANTHROPIC_API_KEY=replace_me_anthropic
# OPENAI_API_KEY=replace_me_openai
# GOOGLE_AI_API_KEY=replace_me_google_ai_studio
TELEGRAM_BOT_TOKEN=replace_me_telegram_token
TELEGRAM_CHAT_ID=replace_me_telegram_chat
DB_PATH=./db/cue.db
CACHE_DIR=./data/cache
UNIVERSE=nasdaq100
MAX_POSITIONS=5
POSITION_SIZE_USD=400
STOP_LOSS_PCT=5
MAX_HOLD_DAYS=20          # Force-exit after this many trading days at next open (see backtest runner)
# Strategy — Exhaustion Entry
SMA_PERIOD=50
BUY_RSI_MAX=60
BUY_VOLUME_RATIO=1.2
EXIT_RSI_THRESHOLD=70
LOG_LEVEL=info
