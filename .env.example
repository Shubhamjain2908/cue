# Massive.com REST API key (https://massive.com/dashboard — rebranded from Polygon.io; env name unchanged)
POLYGON_API_KEY=replace_me_massive
# Optional — unused by Phase 2 enrichment (Yahoo). Keep if you add Alpha Vantage later.
# ALPHA_VANTAGE_API_KEY=

# LLM provider: anthropic | openai | google-studio | vertex | mock | cursor-agent
LLM_PROVIDER=anthropic
LLM_MAX_TOKENS=600

# Anthropic
ANTHROPIC_API_KEY=replace_me_anthropic
ANTHROPIC_MODEL=claude-sonnet-4-20250514
# ANTHROPIC_BASE_URL=https://api.anthropic.com

# OpenAI-compatible (OpenAI, DeepSeek, etc.) — switch vendor by changing OPENAI_BASE_URL only
# OPENAI_API_KEY=replace_me_openai
# OPENAI_MODEL=gpt-4o-mini
# OPENAI_BASE_URL=https://api.openai.com/v1
# DeepSeek example:
# OPENAI_BASE_URL=https://api.deepseek.com/v1
# OPENAI_MODEL=deepseek-chat

# Google AI Studio (Gemini API key)
# GOOGLE_AI_API_KEY=replace_me_google_ai_studio
# GOOGLE_AI_MODEL=gemini-2.0-flash

# Vertex (Gemini on Vertex AI): set VERTEX_PROJECT_ID and auth via GOOGLE_APPLICATION_CREDENTIALS
# VERTEX_PROJECT_ID=my-gcp-project
# VERTEX_LOCATION=us-central1
# VERTEX_MODEL=gemini-2.0-flash-001
# VERTEX_TIMEOUT_MS=120000

# cursor-agent CLI (optional local agent)
# CURSOR_API_KEY=replace_me_cursor
# CURSOR_AGENT_BIN=cursor-agent
# CURSOR_AGENT_MODEL=default
# CURSOR_AGENT_TIMEOUT_MS=300000

TELEGRAM_BOT_TOKEN=replace_me_telegram_token
TELEGRAM_CHAT_ID=replace_me_telegram_chat
DB_PATH=./db/cue.db
# Scheduler cross-process lock (PID file). Default keeps lock next to the DB.
# LOCK_PATH=./db/cue.lock
CACHE_DIR=./data/cache
UNIVERSE=nasdaq100
MAX_POSITIONS=5
POSITION_SIZE_USD=400
STOP_LOSS_PCT=5
MAX_HOLD_DAYS=20          # Force-exit after this many trading days at next open (see backtest runner)
# Strategy — Exhaustion Entry
SMA_PERIOD=50
BUY_RSI_MAX=60
BUY_VOLUME_RATIO=1.2
EXIT_RSI_THRESHOLD=70
LOG_LEVEL=info
