# Massive.com REST API key (https://massive.com/dashboard — rebranded from Polygon.io; env name unchanged)
POLYGON_API_KEY=replace_me_massive
ALPHA_VANTAGE_API_KEY=replace_me_alphavantage
ANTHROPIC_API_KEY=replace_me_anthropic
TELEGRAM_BOT_TOKEN=replace_me_telegram_token
TELEGRAM_CHAT_ID=replace_me_telegram_chat
DB_PATH=./db/cue.db
CACHE_DIR=./data/cache
UNIVERSE=nasdaq100
MAX_POSITIONS=5
POSITION_SIZE_USD=400
STOP_LOSS_PCT=5
MAX_HOLD_DAYS=20          # Force-exit after this many trading days if RSI target not hit
BUY_RSI_THRESHOLD=60          # BUY when RSI is above this (momentum confirmation)
BUY_MOMENTUM_THRESHOLD=3      # BUY when 5d momentum % is above this value
BUY_VOLUME_RATIO=1.3          # BUY when volume ratio is above this (confirmation)
EXIT_RSI_THRESHOLD=45         # SELL when RSI drops below this (momentum fading)
LOG_LEVEL=info
