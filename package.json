{
  "name": "cue",
  "version": "0.1.0",
  "private": true,
  "description": "Cue - US Equity Signal System (Phase 1 scaffold)",
  "type": "module",
  "packageManager": "pnpm@9.15.9",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "db:init": "tsx src/db/schema.ts",
    "screen": "tsx src/strategy/signals.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "fetch": "tsx src/fetcher/index.ts",
    "backtest": "tsx src/backtest/runner.ts",
    "enrich": "tsx src/ai/enrichment.ts",
    "alert": "tsx src/alerts/telegram.ts",
    "dashboard": "tsx src/dashboard/generator.ts",
    "pipeline": "tsx src/pipeline.ts"
  },
  "dependencies": {
    "axios": "^1.7.0",
    "better-sqlite3": "^9.6.0",
    "dotenv": "^16.4.5",
    "node-cron": "^3.0.3",
    "winston": "^3.13.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.10.1",
    "@typescript-eslint/eslint-plugin": "^8.18.1",
    "@typescript-eslint/parser": "^8.18.1",
    "eslint": "^9.17.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^1.6.0"
  },
  "vitest": {
    "environment": "node",
    "include": ["tests/**/*.test.ts"]
  }
}
