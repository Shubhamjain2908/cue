{
  "name": "cue",
  "version": "0.1.0",
  "private": true,
  "description": "Cue - US Equity Signal System (Phase 1 scaffold)",
  "type": "module",
  "packageManager": "pnpm@10.33.2",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=9"
  },
  "scripts": {
    "db:init": "tsx src/db/schema.ts",
    "screen": "tsx src/enrichers/momentum-technical.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "fetch": "tsx src/ingestors/massive-price-ingestor.ts",
    "backtest": "tsx src/backtest/runner.ts",
    "enrich": "tsx src/agents/thesis-generator.ts",
    "alert": "tsx src/briefing/telegram-dispatcher.ts",
    "dashboard": "tsx src/briefing/dashboard.ts",
    "dashboard:open": "tsx src/briefing/dashboard.ts --open",
    "pipeline": "tsx src/agents/daily-workflow.ts",
    "pipeline:now": "tsx src/agents/daily-workflow.ts --now",
    "rebuild:native": "pnpm rebuild better-sqlite3"
  },
  "dependencies": {
    "axios": "^1.7.0",
    "better-sqlite3": "^11.5.0",
    "dotenv": "^16.4.5",
    "google-auth-library": "^9.15.1",
    "node-cron": "^3.0.3",
    "winston": "^3.13.0",
    "yahoo-finance2": "^3.14.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.10.1",
    "@typescript-eslint/eslint-plugin": "^8.18.1",
    "@typescript-eslint/parser": "^8.18.1",
    "eslint": "^9.17.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^1.6.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild"
    ]
  },
  "vitest": {
    "environment": "node",
    "include": [
      "tests/**/*.test.ts"
    ]
  }
}
